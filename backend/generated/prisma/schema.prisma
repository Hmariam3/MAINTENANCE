generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model asset_categories {
  category_id                      Int                                @id @default(autoincrement())
  category_name                    String                             @db.VarChar(100)
  parent_category_id               Int?
  is_active                        Boolean?                           @default(true)
  asset_categories                 asset_categories?                  @relation("asset_categoriesToasset_categories", fields: [parent_category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  other_asset_categories           asset_categories[]                 @relation("asset_categoriesToasset_categories")
  assets                           assets[]
  maintenance_requests             maintenance_requests[]
  preventive_maintenance_schedules preventive_maintenance_schedules[]
}

model asset_status_history {
  history_id         Int       @id @default(autoincrement())
  asset_id           Int
  old_status         String?   @db.VarChar(50)
  new_status         String?   @db.VarChar(50)
  changed_by_user_id Int?
  change_reason      String?
  changed_at         DateTime? @default(now()) @db.Timestamptz(6)
  assets             assets    @relation(fields: [asset_id], references: [asset_id], onDelete: NoAction, onUpdate: NoAction)
  users              users?    @relation(fields: [changed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model assets {
  asset_id                         Int                                @id @default(autoincrement())
  asset_number                     String                             @unique @db.VarChar(50)
  tag_number                       String                             @unique @db.VarChar(50)
  serial_number                    String?                            @db.VarChar(100)
  company_name                     String?                            @db.VarChar(150)
  description                      String?
  category_id                      Int
  brand                            String?                            @db.VarChar(100)
  model                            String?                            @db.VarChar(100)
  cost_center_number               String?                            @db.VarChar(50)
  branch_id                        Int?
  district                         String?                            @db.VarChar(100)
  ip_address                       String?                            @db.Inet
  acquisition_year                 Int?                               @db.SmallInt
  capitalized_on                   DateTime?                          @db.Date
  current_status                   asset_status_enum?                 @default(Active)
  created_at                       DateTime?                          @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime?                          @default(now()) @db.Timestamptz(6)
  asset_status_history             asset_status_history[]
  branches                         branches?                          @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  asset_categories                 asset_categories                   @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests             maintenance_requests[]
  preventive_maintenance_schedules preventive_maintenance_schedules[]
  request_disposal_details         request_disposal_details[]

  @@index([branch_id], map: "idx_assets_branch")
  @@index([category_id], map: "idx_assets_category")
}

model audit_logs {
  audit_id             Int               @id @default(autoincrement())
  table_name           String            @db.VarChar(100)
  record_id            Int
  action_type          audit_action_enum
  field_name           String?           @db.VarChar(100)
  old_value            String?
  new_value            String?
  performed_by_user_id Int?
  performed_at         DateTime?         @default(now()) @db.Timestamptz(6)
  ip_address           String?           @db.Inet
  additional_info      String?           @db.VarChar(500)
  users                users?            @relation(fields: [performed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([table_name, record_id], map: "idx_audit_logs_table_record")
}

model branches {
  branch_id                        Int                                @id @default(autoincrement())
  branch_name                      String                             @db.VarChar(100)
  updated_at                       DateTime?                          @db.Timestamp(6)
  created_at                       DateTime?                          @db.Timestamp(6)
  district                         String?                            @db.VarChar(50)
  branch_code                      String?                            @db.VarChar(50)
  is_active                        Boolean?                           @default(true)
  assets                           assets[]
  maintenance_requests             maintenance_requests[]
  preventive_maintenance_schedules preventive_maintenance_schedules[]
  users                            users[]
}

model electrical_maintenance_details {
  detail_id            Int                  @id @default(autoincrement())
  request_id           Int                  @unique
  maintenance_type     String?              @db.VarChar(100)
  sub_category         String?              @db.VarChar(100)
  quantity             Int?                 @default(1)
  serial_number        String?              @db.VarChar(100)
  model                String?              @db.VarChar(100)
  tag_number           String?              @db.VarChar(50)
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model escalation_rules {
  rule_id             Int                   @id @default(autoincrement())
  rule_name           String?               @db.VarChar(150)
  trigger_type        String?               @db.VarChar(100)
  escalation_level    Int?
  threshold_hours     Int?
  is_active           Boolean?              @default(true)
  request_escalations request_escalations[]
}

model generator_maintenance_details {
  detail_id            Int                  @id @default(autoincrement())
  request_id           Int                  @unique
  generator_category   String?              @db.VarChar(100)
  brand                String?              @db.VarChar(100)
  model                String?              @db.VarChar(100)
  engine_serial_number String?              @db.VarChar(100)
  engine_model         String?              @db.VarChar(100)
  tag_number           String?              @db.VarChar(50)
  engine_running_hours Decimal?             @db.Decimal(10, 2)
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
}

model hardware_maintenance_details {
  detail_id            Int                  @id @default(autoincrement())
  request_id           Int                  @unique
  hardware_type        String?              @db.VarChar(100)
  brand                String?              @db.VarChar(100)
  model                String?              @db.VarChar(100)
  serial_number        String?              @db.VarChar(100)
  tag_number           String?              @db.VarChar(50)
  quantity             Int?                 @default(1)
  ip_address           String?              @db.Inet
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
}

model maintenance_requests {
  request_id                                               Int                             @id @default(autoincrement())
  request_code                                             String?                         @default(dbgenerated("('REQ-'::text || lpad((request_id)::text, 5, '0'::text))")) @db.VarChar(20)
  requester_user_id                                        Int
  branch_id                                                Int
  district                                                 String?                         @db.VarChar(100)
  request_date                                             DateTime                        @default(now()) @db.Timestamptz(6)
  due_date                                                 DateTime?                       @db.Timestamptz(6)
  category_id                                              Int
  asset_id                                                 Int?
  priority_id                                              Int
  status_id                                                Int                             @default(1)
  assigned_technician_id                                   Int?
  assigned_by_user_id                                      Int?
  assigned_at                                              DateTime?                       @db.Timestamptz(6)
  problem_description                                      String
  supervisor_user_id                                       Int?
  supervisor_approved_at                                   DateTime?                       @db.Timestamptz(6)
  completion_date                                          DateTime?                       @db.Timestamptz(6)
  user_approved_closure_at                                 DateTime?                       @db.Timestamptz(6)
  user_approved_by_id                                      Int?
  created_at                                               DateTime?                       @default(now()) @db.Timestamptz(6)
  updated_at                                               DateTime?                       @default(now()) @db.Timestamptz(6)
  electrical_maintenance_details                           electrical_maintenance_details?
  generator_maintenance_details                            generator_maintenance_details?
  hardware_maintenance_details                             hardware_maintenance_details?
  assets                                                   assets?                         @relation(fields: [asset_id], references: [asset_id], onDelete: NoAction, onUpdate: NoAction)
  users_maintenance_requests_assigned_by_user_idTousers    users?                          @relation("maintenance_requests_assigned_by_user_idTousers", fields: [assigned_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  users_maintenance_requests_assigned_technician_idTousers users?                          @relation("maintenance_requests_assigned_technician_idTousers", fields: [assigned_technician_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  branches                                                 branches                        @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  asset_categories                                         asset_categories                @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  priority_levels                                          priority_levels                 @relation(fields: [priority_id], references: [priority_id], onDelete: NoAction, onUpdate: NoAction)
  users_maintenance_requests_requester_user_idTousers      users                           @relation("maintenance_requests_requester_user_idTousers", fields: [requester_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  request_statuses                                         request_statuses                @relation(fields: [status_id], references: [status_id], onDelete: NoAction, onUpdate: NoAction)
  users_maintenance_requests_supervisor_user_idTousers     users?                          @relation("maintenance_requests_supervisor_user_idTousers", fields: [supervisor_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  users_maintenance_requests_user_approved_by_idTousers    users?                          @relation("maintenance_requests_user_approved_by_idTousers", fields: [user_approved_by_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  notifications                                            notifications[]
  preventive_maintenance_logs                              preventive_maintenance_logs[]
  request_disposal_details                                 request_disposal_details[]
  request_escalations                                      request_escalations[]
  request_on_hold_details                                  request_on_hold_details[]
  request_resolution_details                               request_resolution_details?
  request_sla_tracking                                     request_sla_tracking?
  request_spare_parts_used                                 request_spare_parts_used[]
  vendor_request_assignments                               vendor_request_assignments[]

  @@index([branch_id], map: "idx_maintenance_requests_branch")
  @@index([category_id], map: "idx_maintenance_requests_category")
  @@index([request_date], map: "idx_maintenance_requests_date")
  @@index([priority_id], map: "idx_maintenance_requests_priority")
  @@index([requester_user_id], map: "idx_maintenance_requests_requester")
  @@index([status_id], map: "idx_maintenance_requests_status")
  @@index([assigned_technician_id], map: "idx_maintenance_requests_technician")
}

model notification_types {
  notification_type_id Int             @id @default(autoincrement())
  type_name            String          @db.VarChar(100)
  template             String?
  notifications        notifications[]
}

model notifications {
  notification_id      Int                        @id @default(autoincrement())
  notification_type_id Int
  request_id           Int?
  recipient_user_id    Int
  channel              notification_channel_enum? @default(Email)
  subject              String?                    @db.VarChar(200)
  message              String?
  is_sent              Boolean?                   @default(false)
  sent_at              DateTime?                  @db.Timestamptz(6)
  is_read              Boolean?                   @default(false)
  read_at              DateTime?                  @db.Timestamptz(6)
  created_at           DateTime?                  @default(now()) @db.Timestamptz(6)
  notification_types   notification_types         @relation(fields: [notification_type_id], references: [notification_type_id], onDelete: NoAction, onUpdate: NoAction)
  users                users                      @relation(fields: [recipient_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests maintenance_requests?      @relation(fields: [request_id], references: [request_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([recipient_user_id, is_read], map: "idx_notifications_recipient")
}

model on_hold_reasons {
  reason_id               Int                       @id @default(autoincrement())
  reason_text             String                    @db.VarChar(200)
  request_on_hold_details request_on_hold_details[]
}

model preventive_maintenance_logs {
  log_id                                                        Int                              @id @default(autoincrement())
  schedule_id                                                   Int
  performed_by_user_id                                          Int
  performed_date                                                DateTime                         @default(now()) @db.Timestamptz(6)
  notes                                                         String?
  next_scheduled_date                                           DateTime?                        @db.Date
  linked_request_id                                             Int?
  supervisor_user_id                                            Int?
  supervisor_approved_at                                        DateTime?                        @db.Timestamptz(6)
  supervisor_notes                                              String?
  status                                                        String?                          @default("Pending Approval") @db.VarChar(50)
  maintenance_requests                                          maintenance_requests?            @relation(fields: [linked_request_id], references: [request_id], onDelete: NoAction, onUpdate: NoAction)
  users_preventive_maintenance_logs_performed_by_user_idTousers users                            @relation("preventive_maintenance_logs_performed_by_user_idTousers", fields: [performed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  users_preventive_maintenance_logs_supervisor_user_idTousers   users?                           @relation("preventive_maintenance_logs_supervisor_user_idTousers", fields: [supervisor_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  preventive_maintenance_schedules                              preventive_maintenance_schedules @relation(fields: [schedule_id], references: [schedule_id], onDelete: NoAction, onUpdate: NoAction)
}

model preventive_maintenance_schedules {
  schedule_id                                                          Int                           @id @default(autoincrement())
  schedule_name                                                        String                        @db.VarChar(200)
  asset_id                                                             Int?
  category_id                                                          Int?
  brand                                                                String?                       @db.VarChar(100)
  model                                                                String?                       @db.VarChar(100)
  serial_number                                                        String?                       @db.VarChar(100)
  tag_number                                                           String?                       @db.VarChar(50)
  quantity                                                             Int?                          @default(1)
  ip_address                                                           String?                       @db.Inet
  frequency_type                                                       frequency_type_enum?
  frequency_interval                                                   Int?                          @default(1)
  next_due_date                                                        DateTime?                     @db.Date
  assigned_technician_id                                               Int?
  requester_user_id                                                    Int?
  branch_id                                                            Int?
  is_active                                                            Boolean?                      @default(true)
  created_at                                                           DateTime?                     @default(now()) @db.Timestamptz(6)
  preventive_maintenance_logs                                          preventive_maintenance_logs[]
  assets                                                               assets?                       @relation(fields: [asset_id], references: [asset_id], onDelete: NoAction, onUpdate: NoAction)
  users_preventive_maintenance_schedules_assigned_technician_idTousers users?                        @relation("preventive_maintenance_schedules_assigned_technician_idTousers", fields: [assigned_technician_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  branches                                                             branches?                     @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  asset_categories                                                     asset_categories?             @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  users_preventive_maintenance_schedules_requester_user_idTousers      users?                        @relation("preventive_maintenance_schedules_requester_user_idTousers", fields: [requester_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model priority_levels {
  priority_id          Int                    @id @default(autoincrement())
  priority_name        String                 @db.VarChar(20)
  response_hours       Int?
  resolution_hours     Int?
  maintenance_requests maintenance_requests[]
  request_sla_tracking request_sla_tracking[]
}

model request_disposal_details {
  disposal_id                                               Int                  @id @default(autoincrement())
  request_id                                                Int
  asset_id                                                  Int
  disposal_date                                             DateTime?            @db.Date
  reason_for_disposal                                       String
  asset_condition                                           String?              @db.VarChar(100)
  recommendation                                            String?              @db.VarChar(100)
  checked_by_user_id                                        Int?
  approved_by_user_id                                       Int?
  approved_at                                               DateTime?            @db.Timestamptz(6)
  users_request_disposal_details_approved_by_user_idTousers users?               @relation("request_disposal_details_approved_by_user_idTousers", fields: [approved_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  assets                                                    assets               @relation(fields: [asset_id], references: [asset_id], onDelete: NoAction, onUpdate: NoAction)
  users_request_disposal_details_checked_by_user_idTousers  users?               @relation("request_disposal_details_checked_by_user_idTousers", fields: [checked_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests                                      maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
}

model request_escalations {
  escalation_id        Int                  @id @default(autoincrement())
  request_id           Int
  rule_id              Int?
  escalation_level     Int?
  escalated_to_user_id Int?
  escalation_reason    String?
  escalated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  resolved_at          DateTime?            @db.Timestamptz(6)
  is_resolved          Boolean?             @default(false)
  users                users?               @relation(fields: [escalated_to_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: NoAction, onUpdate: NoAction)
  escalation_rules     escalation_rules?    @relation(fields: [rule_id], references: [rule_id], onDelete: NoAction, onUpdate: NoAction)
}

model request_on_hold_details {
  on_hold_id              Int                      @id @default(autoincrement())
  request_id              Int
  reason_id               Int
  hold_start_date         DateTime                 @default(now()) @db.Timestamptz(6)
  expected_resume_date    DateTime?                @db.Timestamptz(6)
  actual_resume_date      DateTime?                @db.Timestamptz(6)
  responsible_party_id    Int?
  remarks                 String?
  recorded_by_user_id     Int?
  on_hold_reasons         on_hold_reasons          @relation(fields: [reason_id], references: [reason_id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?                   @relation(fields: [recorded_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests    maintenance_requests     @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
  responsible_party_types responsible_party_types? @relation(fields: [responsible_party_id], references: [party_type_id], onDelete: NoAction, onUpdate: NoAction)
}

model request_resolution_details {
  resolution_id        Int                  @id @default(autoincrement())
  request_id           Int                  @unique
  hardware_type        String?              @db.VarChar(100)
  serial_number        String?              @db.VarChar(100)
  tag_number           String?              @db.VarChar(50)
  completion_date      DateTime?            @db.Timestamptz(6)
  cost_saved           Decimal?             @default(0) @db.Decimal(18, 2)
  resolution_summary   String?
  resolved_by_user_id  Int?
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
  users                users?               @relation(fields: [resolved_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model request_sla_tracking {
  sla_id                 Int                  @id @default(autoincrement())
  request_id             Int                  @unique
  priority_id            Int
  sla_start_time         DateTime             @db.Timestamptz(6)
  sla_due_time           DateTime             @db.Timestamptz(6)
  actual_completion_time DateTime?            @db.Timestamptz(6)
  sla_status             sla_status_enum?     @default(Pending)
  breach_notified_at     DateTime?            @db.Timestamptz(6)
  priority_levels        priority_levels      @relation(fields: [priority_id], references: [priority_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests   maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sla_status], map: "idx_sla_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model request_spare_parts_used {
  usage_id             Int                  @id @default(autoincrement())
  request_id           Int
  part_id              Int
  quantity_used        Int
  unit_price           Decimal              @db.Decimal(18, 2)
  total_cost           Decimal?             @default(dbgenerated("((quantity_used)::numeric * unit_price)")) @db.Decimal(18, 2)
  issued_by_user_id    Int?
  issued_date          DateTime?            @default(now()) @db.Timestamptz(6)
  users                users?               @relation(fields: [issued_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  spare_parts          spare_parts          @relation(fields: [part_id], references: [part_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: Cascade, onUpdate: NoAction)
}

model request_statuses {
  status_id            Int                    @id @default(autoincrement())
  status_name          String                 @unique @db.VarChar(30)
  responsibility       String?                @db.VarChar(100)
  description          String?                @db.VarChar(200)
  maintenance_requests maintenance_requests[]
}

model responsible_party_types {
  party_type_id           Int                       @id @default(autoincrement())
  party_name              String                    @db.VarChar(100)
  request_on_hold_details request_on_hold_details[]
}

model roles {
  role_id     Int     @id @default(autoincrement())
  role_name   String  @unique @db.VarChar(50)
  description String? @db.VarChar(200)
  users       users[]
}

model spare_parts {
  part_id                  Int                        @id @default(autoincrement())
  part_name                String                     @db.VarChar(150)
  part_number              String                     @unique @db.VarChar(100)
  store_location           String?                    @db.VarChar(100)
  current_stock            Int?                       @default(0)
  low_stock_threshold      Int?                       @default(5)
  unit_price               Decimal?                   @db.Decimal(18, 2)
  is_active                Boolean?                   @default(true)
  created_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  request_spare_parts_used request_spare_parts_used[]

  @@index([current_stock], map: "idx_spare_parts_stock", where: raw("(current_stock <= low_stock_threshold)"))
}

model users {
  user_id                                                                                         Int                                @id @default(autoincrement())
  full_name                                                                                       String                             @db.VarChar(150)
  username                                                                                        String                             @unique @db.VarChar(100)
  email                                                                                           String                             @unique @db.VarChar(150)
  phone_number                                                                                    String?                            @db.VarChar(20)
  role_id                                                                                         Int
  branch_id                                                                                       Int?
  is_active                                                                                       Boolean?                           @default(true)
  created_at                                                                                      DateTime?                          @default(now()) @db.Timestamptz(6)
  asset_status_history                                                                            asset_status_history[]
  audit_logs                                                                                      audit_logs[]
  maintenance_requests_maintenance_requests_assigned_by_user_idTousers                            maintenance_requests[]             @relation("maintenance_requests_assigned_by_user_idTousers")
  maintenance_requests_maintenance_requests_assigned_technician_idTousers                         maintenance_requests[]             @relation("maintenance_requests_assigned_technician_idTousers")
  maintenance_requests_maintenance_requests_requester_user_idTousers                              maintenance_requests[]             @relation("maintenance_requests_requester_user_idTousers")
  maintenance_requests_maintenance_requests_supervisor_user_idTousers                             maintenance_requests[]             @relation("maintenance_requests_supervisor_user_idTousers")
  maintenance_requests_maintenance_requests_user_approved_by_idTousers                            maintenance_requests[]             @relation("maintenance_requests_user_approved_by_idTousers")
  notifications                                                                                   notifications[]
  preventive_maintenance_logs_preventive_maintenance_logs_performed_by_user_idTousers             preventive_maintenance_logs[]      @relation("preventive_maintenance_logs_performed_by_user_idTousers")
  preventive_maintenance_logs_preventive_maintenance_logs_supervisor_user_idTousers               preventive_maintenance_logs[]      @relation("preventive_maintenance_logs_supervisor_user_idTousers")
  preventive_maintenance_schedules_preventive_maintenance_schedules_assigned_technician_idTousers preventive_maintenance_schedules[] @relation("preventive_maintenance_schedules_assigned_technician_idTousers")
  preventive_maintenance_schedules_preventive_maintenance_schedules_requester_user_idTousers      preventive_maintenance_schedules[] @relation("preventive_maintenance_schedules_requester_user_idTousers")
  request_disposal_details_request_disposal_details_approved_by_user_idTousers                    request_disposal_details[]         @relation("request_disposal_details_approved_by_user_idTousers")
  request_disposal_details_request_disposal_details_checked_by_user_idTousers                     request_disposal_details[]         @relation("request_disposal_details_checked_by_user_idTousers")
  request_escalations                                                                             request_escalations[]
  request_on_hold_details                                                                         request_on_hold_details[]
  request_resolution_details                                                                      request_resolution_details[]
  request_spare_parts_used                                                                        request_spare_parts_used[]
  branches                                                                                        branches?                          @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  roles                                                                                           roles                              @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction)
}

model vendor_contracts {
  contract_id                Int                          @id @default(autoincrement())
  vendor_id                  Int
  contract_number            String                       @unique @db.VarChar(100)
  contract_start_date        DateTime                     @db.Date
  contract_end_date          DateTime                     @db.Date
  contract_value             Decimal?                     @db.Decimal(18, 2)
  notes                      String?
  is_active                  Boolean?                     @default(true)
  created_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  vendors                    vendors                      @relation(fields: [vendor_id], references: [vendor_id], onDelete: NoAction, onUpdate: NoAction)
  vendor_request_assignments vendor_request_assignments[]
}

model vendor_request_assignments {
  assignment_id        Int                  @id @default(autoincrement())
  request_id           Int
  vendor_id            Int
  contract_id          Int?
  assigned_at          DateTime?            @default(now()) @db.Timestamptz(6)
  completed_at         DateTime?            @db.Timestamptz(6)
  vendor_feedback      String?
  vendor_contracts     vendor_contracts?    @relation(fields: [contract_id], references: [contract_id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_requests maintenance_requests @relation(fields: [request_id], references: [request_id], onDelete: NoAction, onUpdate: NoAction)
  vendors              vendors              @relation(fields: [vendor_id], references: [vendor_id], onDelete: NoAction, onUpdate: NoAction)
}

model vendors {
  vendor_id                  Int                          @id @default(autoincrement())
  vendor_name                String                       @db.VarChar(150)
  service_type               String?                      @db.VarChar(100)
  contact_person             String?                      @db.VarChar(150)
  phone_number               String?                      @db.VarChar(20)
  email_address              String?                      @db.VarChar(150)
  is_active                  Boolean?                     @default(true)
  created_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  vendor_contracts           vendor_contracts[]
  vendor_request_assignments vendor_request_assignments[]
}

model processess {
  id             BigInt           @id @default(autoincrement())
  process_name   String?          @db.VarChar(255)
  created_date   DateTime?        @db.Date
  updated_date   DateTime?        @db.Date
  process_acrnm  String?          @db.VarChar(50)
  sub_processess sub_processess[]
}

model sub_processess {
  id               BigInt      @id @default(autoincrement())
  process_name     String?     @db.VarChar(255)
  created_date     DateTime?   @db.Date
  process_id       BigInt?
  updated_date     DateTime?   @db.Timestamptz(6)
  subprocess_acrnm String?     @db.VarChar(50)
  processess       processess? @relation(fields: [process_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum asset_status_enum {
  Active
  Under_Maintenance @map("Under Maintenance")
  Disposed
  Replaced
}

enum audit_action_enum {
  INSERT
  UPDATE
  DELETE
}

enum frequency_type_enum {
  Daily
  Weekly
  Monthly
  Quarterly
  Annually
}

enum notification_channel_enum {
  Email
  SMS
  Dashboard
}

enum request_status_enum {
  Open
  Assigned
  In_Progress @map("In Progress")
  On_Hold     @map("On Hold")
  Completed
  Disposal
}

enum sla_status_enum {
  Pending
  Met
  Breached
}
